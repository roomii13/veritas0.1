EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
VERITAS_ALLOW_HEURISTIC_FALLBACK=false
VERITAS_MAX_UPLOAD_MB=120
VERITAS_ALLOW_PRIVATE_URLS=false
VERITAS_DEVICE=auto
VERITAS_USE_FP16=auto
VERITAS_MEDIUM_RISK_THRESHOLD=60
VERITAS_PREVENTION_THRESHOLD=70
VERITAS_HIGH_RISK_THRESHOLD=80
DEEPFAKE_MODEL_NAME=prithivMLmods/deepfake-detector-model-v1
# IMAGE_MODEL_NAMES=prithivMLmods/deepfake-detector-model-v1,capcheck/ai-image-detection
IMAGE_MODEL_NAMES=capcheck/ai-image-detection
IMAGE_DETECTOR_SIZE=224
IMAGE_UNTRUSTED_THRESHOLD=60
AUDIO_DEEPFAKE_MODEL_NAME=Gustking/wav2vec2-large-xlsr-deepfake-audio-classification
AUDIO_TARGET_SR=16000
AUDIO_MAX_DURATION_SEC=60
AUDIO_MIN_DURATION_SEC=1
AUDIO_UNTRUSTED_THRESHOLD=30
VIDEO_MAX_FRAMES=12
VIDEO_SAMPLE_METHOD=uniform
VIDEO_FAKE_RATIO_THRESHOLD=0.30
VIDEO_FRAME_WORKERS=4
VIDEO_UNTRUSTED_THRESHOLD=30
LINK_SUSPICIOUS_THRESHOLD=45
LINK_UNTRUSTED_THRESHOLD=45
LINK_EXPAND_SHORTENERS=false
